# Environment template for local dev and CI (e.g. Playwright copies this to `.env`).
#
# - `.env` — gitignored (same as `.env.local`). Create from this file: `cp .env.example .env`
#   and fill in anything missing. Used by the dev server and by CI E2E (via copy of this template).
# - `.env.local` — gitignored; optional overrides and secrets on top of `.env`. Playwright loads
#   `.env.local` when present (see `playwright.config.ts`).
# - CI: the E2E workflow runs `cp .env.example .env` so the dev server starts without repo secrets.
#   Add GitHub Actions secrets and a workflow step to write `.env` if you need more than this file.

# Include this environment variable if you want more logging for debugging locally
VITE_LOG_LEVEL=debug

# set these to enable opentelemetry
HONEYCOMB_API_KEY=
HONEYCOMB_DATASET=

# If you're using Sentry for error tracking, include your Sentry Auth token here to upload sourcemaps
SENTRY_AUTH_TOKEN=

# Supabase Configuration
SUPABASE_URL=https://auth.nut.new
SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJpc3MiOiJzdXBhYmFzZSIsInJlZiI6Inpia2NhdnhpZGp5c2xxbW5iZnV4Iiwicm9sZSI6ImFub24iLCJpYXQiOjE3NDAwMDU0MjAsImV4cCI6MjA1NTU4MTQyMH0.xHKTareBFW0LW0AmYXH0vOvU3mLB3jkQGwhoNWqpnTw

# Find these in the vercel dashboard
STRIPE_SECRET_KEY=
STRIPE_PUBLISHABLE_KEY=

# Exposed to the client via root loader (optional; empty is fine for local / CI smoke tests)
INTERCOM_APP_ID=

# Replay.io Playwright (local: key here or `.env.local`; run `pnpm exec replayio install` for replay-chromium.
# CI: repo secret + workflow env. PR result comments need the Replay GitHub App on the repo.)
REPLAY_API_KEY=

# Segment Analytics (server-side write key)
SEGMENT_WRITE_KEY=

VITE_AUTH_SUPABASE_URL=https://auth.nut.new
VITE_AUTH_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJpc3MiOiJzdXBhYmFzZSIsInJlZiI6Inpia2NhdnhpZGp5c2xxbW5iZnV4Iiwicm9sZSI6ImFub24iLCJpYXQiOjE3NDAwMDU0MjAsImV4cCI6MjA1NTU4MTQyMH0.xHKTareBFW0LW0AmYXH0vOvU3mLB3jkQGwhoNWqpnTw
